<section{{ attributes.defaults({class: 'todo-shell'}) }}>
    <h2 class="mb-3" style="text-align: center;">My Todo List with LiveComponent</h2>
    <header class="todo-shell__header">
        <twig:TodoStats
            key="stats-{{ listVersion }}"
            :totalTodos="computed.totalTodos"
            :remaining="computed.remainingCount"
            :completedCount="computed.completedCount"
        />
    </header>

    <div class="todo-search">
        <label for="todo-search-input" class="sr-only">Search todos by title</label>
        <input
            id="todo-search-input"
            type="text"
            class="todo-search__input"
            placeholder="Search by title"
            data-model="searchQuery"
            data-action="input->live#action"
            data-live-action-param="searchTodos"
        >
        {% if searchQuery %}
            <button
                type="button"
                class="todo-search__clear"
                data-action="live#action"
                data-live-action-param="clearSearch"
                aria-label="Clear search"
            >
                X
            </button>
        {% endif %}
    </div>

    <div class="todo-list" data-loading="addClass(is-loading)">
        {% for todo in computed.paginatedTodos %}
            <article key="todo-{{ todo.id }}" class="todo-card{{ todo.done ? ' is-done' }}">
                <input
                    type="checkbox"
                    class="todo-card__toggle"
                    data-action="live#action"
                    data-live-action-param="toggleTodo"
                    data-live-todo-param="{{ todo.id }}"
                    {% if todo.done %}checked{% endif %}
                    aria-label="{{ todo.done ? 'Mark as open' : 'Mark as complete' }}"
                >

                <div class="todo-card__content">
                    {% if editingTodoId == todo.id %}
                        <twig:EditTodo
                            key="edit-{{ todo.id }}"
                            todoId="{{ todo.id }}"
                            dataModel="listVersion"
                        />
                    {% else %}
                        <p class="todo-card__title">{{ todo.title }}</p>
                        {% if todo.description %}
                            <p class="todo-card__description">{{ todo.description }}</p>
                        {% endif %}
                        <p class="todo-card__meta">Created {{ todo.createdAt|date('M j, Y \\a\\t H:i') }}</p>
                    {% endif %}
                </div>

                <div class="todo-card__actions">
                    {% if editingTodoId == todo.id %}
                        <button
                            type="button"
                            class="todo-card__edit"
                            data-action="live#action"
                            data-live-action-param="cancelEdit"
                        >
                            Cancel
                        </button>
                    {% else %}
                        <button
                            type="button"
                            class="todo-card__edit"
                            data-action="live#action"
                            data-live-action-param="startEdit"
                            data-live-todo-param="{{ todo.id }}"
                        >
                            Edit
                        </button>
                    {% endif %}

                    <button
                        type="button"
                        class="todo-card__delete"
                        data-action="live#action"
                        data-live-action-param="deleteTodo"
                        data-live-todo-param="{{ todo.id }}"
                    >
                        Remove
                    </button>
                </div>
            </article>
        {% else %}
            <div class="todo-empty">
                <strong>No tasks yet.</strong>
                <p>Add the first one above to see the live component update in place.</p>
            </div>
        {% endfor %}
    </div>
    <p class="todo-hint" style="text-align: center;">Count on current page: {{ computed.paginatedTodos|length }}</p>

    <div class="todo-pagination">
        <a
            href="{{ path('todo_path', {'page': currentPage - 1}) }}"
            class="todo-pagination__button{{ currentPage <= 1 ? ' is-disabled' }}"
            aria-disabled="{{ currentPage <= 1 ? 'true' : 'false' }}"
        >
            Prev
        </a>

        <span class="todo-pagination__indicator">{{ currentPage }}/{{ totalPages }}</span>

        <a
            href="{{ path('todo_path', {'page': currentPage + 1}) }}"
            class="todo-pagination__button{{ currentPage >= totalPages ? ' is-disabled' }}"
            aria-disabled="{{ currentPage >= totalPages ? 'true' : 'false' }}"
        >
            Next
        </a>
    </div>

    <twig:CreateTodo dataModel="listVersion" />
</section>
